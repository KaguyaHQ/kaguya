# Kaguya environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# Derived from config/runtime.exs. Vars marked (required) have no default; the
# app refuses to boot without them. All others are optional (defaults shown).

# ── Core (required) ─────────────────────────────────────────────────────────
# Postgres connection string, e.g. ecto://user:pass@localhost/kaguya_dev
DATABASE_URL=
# Phoenix secret key base. Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# ── Object storage — Cloudflare R2 / S3-compatible (required) ────────────────
R2_APPLICATION_KEY_ID=
R2_APPLICATION_KEY=
R2_BUCKET_NAME=
# Cloudflare R2 account id (endpoint becomes <id>.r2.cloudflarestorage.com).
# Or set R2_ENDPOINT to the full host to override.
R2_ACCOUNT_ID=
# R2_ENDPOINT=

# ── Search — Meilisearch (required) ─────────────────────────────────────────
MEILI_BASE_URL=http://localhost:7700
MEILI_MASTER_KEY=

# ── HTTP / runtime (optional) ───────────────────────────────────────────────
PHX_HOST=localhost
PORT=4000
FRONTEND_URL=https://kaguya.io
DNS_CLUSTER_QUERY=
LOG_LEVEL=info
USE_IPV4=false

# ── Database tuning (optional) ──────────────────────────────────────────────
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=
DATABASE_APPLICATION_NAME=kaguya_phoenix

# ── Server-side rendering bridge (optional) ─────────────────────────────────
SSR_SECRET=

# ── Observability — Axiom log drain (optional) ──────────────────────────────
AXIOM_TOKEN=
AXIOM_DATASET=

# ── Observability — Sentry (optional) ───────────────────────────────────────
SENTRY_DSN=
SENTRY_BROWSER_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# ── Auth — Google OAuth (optional) ──────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ── Email — AWS SES SMTP (optional; falls back to local/dev mailer) ─────────
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com

# ── CDN — Cloudflare cache purge (optional) ─────────────────────────────────
CF_ZONE_ID=
CF_API_TOKEN=

# ── Recommendations / images (optional) ─────────────────────────────────────
# Directory holding the trained EASE model artifacts; defaults to priv/data.
KAGUYA_MODEL_DIR=
# Set to "true" to skip image downloads during the VNDB dump image step.
SKIP_IMAGE_DOWNLOAD=
